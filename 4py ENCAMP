from datetime import datetime

class Libro:
    def __init__(self, titulo, autor, anio_publicacion):
        self._titulo = titulo
        self._autor = autor
        self._anio_publicacion = anio_publicacion

    def descripcion(self):
        return f"{self._titulo} de {self._autor}, publicado en {self._anio_publicacion}"

    def es_clasico(self):
        anio_actual = datetime.now().year
        return (anio_actual - self._anio_publicacion) > 50

    def get_titulo(self):
        return self._titulo

    def set_titulo(self, titulo):
        self._titulo = titulo

    def get_autor(self):
        return self._autor

    def set_autor(self, autor):
        self._autor = autor

    def get_anio_publicacion(self):
        return self._anio_publicacion

    def set_anio_publicacion(self, anio):
        self._anio_publicacion = anio


if __name__ == "__main__":
    libro1 = Libro("Cien años de soledad", "Rosa Melano", 1967)
    print(libro1.descripcion())

    if libro1.es_clasico():
        print("Es un clásico")
    else:
        print("No es un clásico")
